{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "bun"],
    "verbatimModuleSyntax": true
  },
  "include": ["extensions/**/*.ts", "tests/**/*.ts"]
}
